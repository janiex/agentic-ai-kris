# ─── LLM backend ─────────────────────────────────────────────────────────────
# Which provider to use by default: "ollama" (local) or "anthropic" (Claude API).
LLM_PROVIDER=ollama

# Local Ollama backend
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# External Anthropic (Claude) backend
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─── Orchestration ───────────────────────────────────────────────────────────
# Max Researcher<->Critic review rounds before the Summarizer documents the result.
MAX_REVIEW_ROUNDS=3

# ─── Skills ──────────────────────────────────────────────────────────────────
# Directory holding Anthropic-format skill packages (each a folder with SKILL.md).
# Relative paths are resolved against the project root.
SKILLS_DIR=skills

# ─── RAG (future integration) ────────────────────────────────────────────────
# When false, an in-memory stub retriever is used. The pgvector backend below is
# a documented skeleton, not yet implemented.
RAG_ENABLED=false
RETRIEVAL_TOP_K=5

# Postgres + pgvector (only used once the real RAG backend lands)
PGHOST=localhost
PGPORT=5432
PGUSER=agent_user
PGPASSWORD=agent_pass
PGDATABASE=agent_db
